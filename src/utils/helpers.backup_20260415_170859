/**
 * Get subjects by year level
 */
export function getSubjectsByYearLevel(subjects, yearLevel) {
  if (!subjects || !yearLevel) return subjects || [];
  return subjects.filter(s => {
    // Include if subject matches year level OR has no year level (all years)
    return !s.level || 
           s.level === '' || 
           String(s.level) === String(yearLevel);
  });
}

