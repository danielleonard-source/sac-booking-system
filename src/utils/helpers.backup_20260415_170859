/**
 * Parse learners field - handles array, comma-separated string, JSON array string
 */
export function parseLearnersField(learners) {
  if (!learners) return [];
  
  // Already an array
  if (Array.isArray(learners)) return learners;
  
  // JSON string array
  if (typeof learners === 'string') {
    // Try parsing JSON array
    if (learners.startsWith('[')) {
      try {
        const parsed = JSON.parse(learners);
        return Array.isArray(parsed) ? parsed : [learners];
      } catch (e) {
        // Not valid JSON, treat as comma-separated
      }
    }
    
    // Comma-separated string
    if (learners.includes(',')) {
      return learners.split(',').map(s => s.trim()).filter(Boolean);
    }
    
    // Single learner ID/name
    return [learners];
  }
  
  // Fallback: treat as single item
  return [learners];
}

/**
 * Parse reader/writers field - handles object, JSON string
 */
export function parseReaderWritersField(readerWriters) {
  if (!readerWriters) return {};
  
  // Already an object
  if (typeof readerWriters === 'object' && !Array.isArray(readerWriters)) {
    return readerWriters;
  }
  
  // JSON string
  if (typeof readerWriters === 'string') {
    if (readerWriters.startsWith('{')) {
      try {
        return JSON.parse(readerWriters);
      } catch (e) {
        console.warn('Failed to parse readerWriters JSON:', readerWriters);
        return {};
      }
    }
  }
  
  return {};
}

