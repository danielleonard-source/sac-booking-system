  const learnerNames = learners.map(l => `${l.firstName} ${l.lastName}`).join(', ');
  
  const subject = isTeacher 
    ? `SAC Booking Confirmation - ${booking.date}`
    : `SAC Booking - ${booking.subject}`;

  const body = `
═══════════════════════════════════════
📅 SAC BOOKING CONFIRMATION
═══════════════════════════════════════

Date: ${booking.date}
Day: ${booking.day}
Period: ${booking.period}
Subject: ${booking.subject}
Room: ${booking.room}

${isTeacher ? `Teacher: ${booking.teacher}` : `Learners: ${learnerNames}`}

Status: ${booking.status}

${booking.multiSessionReason ? `
Multi-Session Booking: ${booking.totalSessions} sessions
Reason: ${booking.multiSessionReason}
` : ''}

Thank you,
SAC Booking System
`;

  return {
    subject,
    body: body.trim()
  };
}

export function copyEmailToClipboard(email) {
  if (navigator.clipboard && navigator.clipboard.writeText) {
    return navigator.clipboard.writeText(email.body)
      .then(() => true)
      .catch(() => false);
  }
  
  // Fallback
  const textArea = document.createElement('textarea');
  textArea.value = email.body;
  textArea.style.position = 'fixed';
  textArea.style.left = '-999999px';
  document.body.appendChild(textArea);
  textArea.select();
  
  try {
    document.execCommand('copy');
    document.body.removeChild(textArea);
    return Promise.resolve(true);
  } catch (err) {
    document.body.removeChild(textArea);
    return Promise.resolve(false);
  }
}

