// Get week dates from a start date
export function getWeekDates(startDate) {
  const dates = [];
  const current = new Date(startDate);
  
  // Set to Monday of the week
  const day = current.getDay();
  const diff = day === 0 ? -6 : 1 - day;
  current.setDate(current.getDate() + diff);
  
  // Get 5 weekdays
  for (let i = 0; i < 5; i++) {
    const date = new Date(current);
    date.setDate(current.getDate() + i);
    dates.push(getLocalDateString(date));
  }
  
  return dates;
}

// Get periods available for a specific day
export function getPeriodsForDay(schedule, dayName) {
  if (!schedule || !schedule[dayName]) return [];
  return Object.keys(schedule[dayName]).sort();
}

// Get slot status (available/limited/full/blocked)
export function getSlotStatus(bookings, blockedSlots, sessionCapacities, dateStr, dayName, period) {
  // Check if blocked
  const isBlocked = blockedSlots?.some(bs => 
    bs.date === dateStr && bs.period === period
  );
  if (isBlocked) return 'blocked';
  
  // Count confirmed bookings for this slot
  const confirmedBookings = bookings?.filter(b => 
    (b.status === 'confirmed' || b.status === 'approved') &&
    getLocalDateString(new Date(b.date)) === dateStr && 
    String(b.period) === String(period)
  ) || [];
  
  // Get max capacity for this slot (default 10)
  const maxCapacity = sessionCapacities?.[dateStr]?.[period] || 10;
  
  const bookedCount = confirmedBookings.length;
  
  if (bookedCount >= maxCapacity) return 'full';
  if (bookedCount >= maxCapacity * 0.7) return 'limited';
  return 'available';
}

// Get day name from date string
export function getDayName(dateStr) {
  const date = new Date(dateStr);
  const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  return days[date.getDay()];
}
