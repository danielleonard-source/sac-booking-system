export function getLocalDateString(date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}



/**
 * Calculate 3 business day rule
 * Example: Booking on Wednesday = can book from Monday onwards (Wed + Thu + Fri = 3 business days)
 * Weekends don't count as business days
 */
export function getEarliestBookableDate() {
  const now = new Date();
  now.setHours(0, 0, 0, 0);
  
  let businessDaysToAdd = 3;
  let currentDate = new Date(now);
  
  while (businessDaysToAdd > 0) {
    currentDate.setDate(currentDate.getDate() + 1);
    const dayOfWeek = currentDate.getDay();
    
    // Skip weekends (0 = Sunday, 6 = Saturday)
    if (dayOfWeek !== 0 && dayOfWeek !== 6) {
      businessDaysToAdd--;
    }
  }
  
  return currentDate;
}

/**
 * Check if a date is bookable based on 3 business day rule
 */
export function isSlotBookable(date, period) {
  const slotDate = new Date(date);
  slotDate.setHours(0, 0, 0, 0);
  
  const earliestDate = getEarliestBookableDate();
  
  return slotDate >= earliestDate;
}

/**
 * Check if a date is in the past
 */
export function isPastDate(date) {
  const slotDate = new Date(date);
  slotDate.setHours(0, 0, 0, 0);
  
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  
  return slotDate < today;
}

/**
 * Check if booking can be edited or deleted (same 3 business day rule)
 */
export function canEditOrDelete(bookingDate) {
  const booking = new Date(bookingDate);
  booking.setHours(0, 0, 0, 0);
  
  const earliestDate = getEarliestBookableDate();
  
  return booking >= earliestDate;
}

export function formatHoursMinutes(decimalHours) {
  if (!decimalHours || decimalHours === 0) return '0h';
  const hours = Math.floor(decimalHours);
  const minutes = Math.round((decimalHours - hours) * 60);
  
  if (hours === 0) return `${minutes}m`;
  if (minutes === 0) return `${hours}h`;
  return `${hours}h ${minutes}m`;
}

export function getCapacityKey(slot) {
  return `${slot.date}_${slot.day}_${slot.period}`;
}

/**
 * Generate unique ID for new records
 */
export function generateUniqueId() {
  return Date.now().toString() + '_' + Math.random().toString(36).substr(2, 9);
}

/**
 * Alias for generateUniqueId (used in some components)
 */
export function generateId() {
  return generateUniqueId();
}

