/**
 * Find learner by ID with name fallback
 */
export function findLearnerById(learners, learnerId, learnerName = null) {
  if (!learners || !learnerId) return null;
  
  // Try to find by ID first
  let learner = learners.find(l => l.id === learnerId);
  
  // If not found and learnerName provided, try name-based lookup
  if (!learner && learnerName) {
    learner = learners.find(l => {
      const fullName = `${l.firstName || ''} ${l.lastName || ''}`.trim();
      return fullName === learnerName || l.name === learnerName;
    });
  }
  
  if (learner) {
    return {
      ...learner,
      displayName: `${learner.firstName || ''} ${learner.lastName || ''}`.trim() || 
                   learner.name || 
                   `Unknown Learner (${learnerId})`
    };
  }
  return null;
}

/**
 * Get learners by year level
 */
export function getLearnersByYearLevel(learners, yearLevel) {
  if (!learners || !yearLevel) return learners || [];
  return learners.filter(l => String(l.yearLevel) === String(yearLevel));
}

/**
 * Get learners with SAC conditions only
 */
export function getLearnersWithSAC(learners) {
  if (!learners) return [];
  return learners.filter(l => {
    // Has SAC conditions and not declined
    const hasSAC = l.sacConditions && 
                   l.sacConditions !== '' && 
                   l.sacConditions !== '[]' &&
                   l.sacConditions !== 'null';
    const notDeclined = !l.isDeclined;
    return hasSAC && notDeclined;
  });
}

/**
 * Get learners by year level with SAC
 */
export function getLearnersByYearLevelWithSAC(learners, yearLevel) {
  if (!learners || !yearLevel) return [];
  const byYear = getLearnersByYearLevel(learners, yearLevel);
  return getLearnersWithSAC(byYear);
}

/**
 * Parse SAC conditions string to array
 */
export function getConditionsArray(sacConditions) {
  if (!sacConditions) return [];
  
  // If already array
  if (Array.isArray(sacConditions)) return sacConditions;
  
  // If JSON string array
  if (typeof sacConditions === 'string') {
    // Try parsing JSON
    if (sacConditions.startsWith('[')) {
      try {
        const parsed = JSON.parse(sacConditions);
        return Array.isArray(parsed) ? parsed : [];
      } catch (e) {
        // Not valid JSON, treat as comma-separated
      }
    }
    
    // Comma-separated string
    return sacConditions.split(',').map(s => s.trim()).filter(Boolean);
  }
  
  return [];
}

