/**
 * Get R/W display name
 */
export function getReaderWriterName(rw) {
  if (!rw) return '';
  
  if (rw.name) return rw.name;
  
  const firstName = rw.firstName || '';
  const lastName = rw.lastName || '';
  return `${firstName} ${lastName}`.trim() || 'Unknown R/W';
}

/**
 * Check if R/W is available on a day
 */
export function isReaderWriterAvailable(rw, dayName) {
  if (!rw || !rw.daysAvailable) return true; // Assume available if not specified
  
  const daysAvailable = rw.daysAvailable.toLowerCase();
  return daysAvailable.includes(dayName.toLowerCase());
}

