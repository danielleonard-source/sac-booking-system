/**
 * Validate booking form data
 */
export function validateBookingForm(formData) {
  const errors = [];
  
  // Required fields
  if (!formData.date) errors.push('Date is required');
  if (!formData.day) errors.push('Day is required');
  if (!formData.period) errors.push('Period is required');
  if (!formData.teacher) errors.push('Teacher is required');
  if (!formData.subject) errors.push('Subject is required');
  if (!formData.room) errors.push('Room is required');
  if (!formData.learners || formData.learners.length === 0) {
    errors.push('At least one learner must be selected');
  }
  
  // Validate email format if provided
  if (formData.teacherEmail && !isValidEmail(formData.teacherEmail)) {
    errors.push('Invalid teacher email format');
  }
  
  // Validate year level
  if (formData.yearLevel && !isValidYearLevel(formData.yearLevel)) {
    errors.push('Invalid year level');
  }
  
  return {
    isValid: errors.length === 0,
    errors
  };
}

/**
 * Validate email format
 */
export function isValidEmail(email) {
  if (!email) return false;
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  return emailRegex.test(email);
}

/**
 * Validate year level
 */
export function isValidYearLevel(yearLevel) {
  const year = parseInt(yearLevel);
  return year >= 7 && year <= 13;
}

/**
 * Check if array has duplicates
 */
export function hasDuplicates(arr) {
  return new Set(arr).size !== arr.length;
}

