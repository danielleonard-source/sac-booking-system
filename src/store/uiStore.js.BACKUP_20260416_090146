// =======================================
// UI STORE - Modals, Views, UI State
// =======================================

import { create } from 'zustand'

export const useUIStore = create((set) => ({
  // View state
  currentView: 'calendar',
  adminTab: 'learners',
  selectedWeek: 0,

  // Modal states - INDIVIDUAL FLAGS for each modal
  bookingFormOpen: false,
  bookingFormDefaults: null,
  editingBooking: null,
  
  emailConfirmOpen: false,
  emailConfirmData: null,
  
  declineModalOpen: false,
  declineBooking: null,
  
  assignRWModalOpen: false,
  selectedBooking: null,
  
  historyModalOpen: false,
  historyBooking: null,
  
  // Admin modals

  // Capacity and blocking modals
  capacityModalOpen: false,
  capacityModalData: null,

  blockSlotModalOpen: false,
  blockSlotModalData: null,
  showLearnerForm: false,
  editingLearner: null,
  
  showTeacherForm: false,
  editingTeacher: null,
  
  showRWForm: false,
  editingRW: null,
  
  showVenueForm: false,
  editingVenue: null,
  
  showSubjectForm: false,
  editingSubject: null,

  // Search states
  searches: {
    learner: '',
    teacher: '',
    readerWriter: '',
    subject: '',
    venue: '',
    declined: ''
  },

  // Loading overlay
  showLoading: false,
  loadingMessage: 'Loading...',

  // Notification toast
  notification: {
    show: false,
    message: '',
    type: 'info'
  },

  // Actions
  setView: (view) => set({ currentView: view }),
  
  setAdminTab: (tab) => set({ adminTab: tab }),

  // Capacity modal functions
  openCapacityModal: (data) => set({ capacityModalOpen: true, capacityModalData: data }),
  closeCapacityModal: () => set({ capacityModalOpen: false, capacityModalData: null }),

  // Block slot modal functions
  openBlockSlotModal: (data) => set({ blockSlotModalOpen: true, blockSlotModalData: data }),
  closeBlockSlotModal: () => set({ blockSlotModalOpen: false, blockSlotModalData: null }),
  
  setSelectedWeek: (week) => set({ selectedWeek: week }),

  // Booking Form Modal
  openBookingForm: (defaults = null, booking = null) => 
    set({ 
      bookingFormOpen: true, 
      bookingFormDefaults: defaults,
      editingBooking: booking 
    }),
  
  closeBookingForm: () => 
    set({ 
      bookingFormOpen: false, 
      bookingFormDefaults: null,
      editingBooking: null 
    }),

  // Email Confirm Modal
  openEmailConfirm: (data) => 
    set({ emailConfirmOpen: true, emailConfirmData: data }),
  
  closeEmailConfirm: () => 
    set({ emailConfirmOpen: false, emailConfirmData: null }),

  // Decline Modal
  openDeclineModal: (booking) => 
    set({ declineModalOpen: true, declineBooking: booking }),
  
  closeDeclineModal: () => 
    set({ declineModalOpen: false, declineBooking: null }),

  // Assign R/W Modal
  openAssignRWModal: (booking) => 
    set({ assignRWModalOpen: true, selectedBooking: booking }),
  
  closeAssignRWModal: () => 
    set({ assignRWModalOpen: false, selectedBooking: null }),

  // History Modal
  openHistoryModal: (booking) => 
    set({ historyModalOpen: true, historyBooking: booking }),
  
  closeHistoryModal: () => 
    set({ historyModalOpen: false, historyBooking: null }),

  // Admin Form Modals
  openLearnerForm: (learner = null) => 
    set({ showLearnerForm: true, editingLearner: learner }),
  
  closeLearnerForm: () => 
    set({ showLearnerForm: false, editingLearner: null }),

  openTeacherForm: (teacher = null) => 
    set({ showTeacherForm: true, editingTeacher: teacher }),
  
  closeTeacherForm: () => 
    set({ showTeacherForm: false, editingTeacher: null }),

  openRWForm: (rw = null) => 
    set({ showRWForm: true, editingRW: rw }),
  
  closeRWForm: () => 
    set({ showRWForm: false, editingRW: null }),

  openVenueForm: (venue = null) => 
    set({ showVenueForm: true, editingVenue: venue }),
  
  closeVenueForm: () => 
    set({ showVenueForm: false, editingVenue: null }),

  openSubjectForm: (subject = null) => 
    set({ showSubjectForm: true, editingSubject: subject }),
  
  closeSubjectForm: () => 
    set({ showSubjectForm: false, editingSubject: null }),

  // Generic modal opener (for backward compatibility)
  openModal: (modalName, data = null) => {
    switch(modalName) {
      case 'bookingForm':
        set({ bookingFormOpen: true, bookingFormDefaults: data });
        break;
      case 'emailConfirm':
        set({ emailConfirmOpen: true, emailConfirmData: data });
        break;
      case 'decline':
        set({ declineModalOpen: true, declineBooking: data });
        break;
      case 'assignRW':
        set({ assignRWModalOpen: true, selectedBooking: data });
        break;
      case 'history':
        set({ historyModalOpen: true, historyBooking: data });
        break;
      case 'capacity':
        set({ capacityModalOpen: true, capacityModalData: data });
        break;
      case 'blockSlot':
        set({ blockSlotModalOpen: true, blockSlotModalData: data });
        break;
      default:
        console.warn('Unknown modal:', modalName);
    }
  },

  closeModal: (modalName) => {
    switch(modalName) {
      case 'bookingForm':
        set({ bookingFormOpen: false, bookingFormDefaults: null, editingBooking: null });
        break;
      case 'emailConfirm':
        set({ emailConfirmOpen: false, emailConfirmData: null });
        break;
      case 'decline':
        set({ declineModalOpen: false, declineBooking: null });
        break;
      case 'assignRW':
        set({ assignRWModalOpen: false, selectedBooking: null });
        break;
      case 'history':
      case 'capacity':
        set({ capacityModalOpen: false, capacityModalData: null });
        break;
      case 'blockSlot':
        set({ blockSlotModalOpen: false, blockSlotModalData: null });
        break;
        set({ historyModalOpen: false, historyBooking: null });
        break;
      default:
        console.warn('Unknown modal:', modalName);
    }
  },

  closeAllModals: () =>
    set({
      bookingFormOpen: false,
      bookingFormDefaults: null,
      editingBooking: null,
      emailConfirmOpen: false,
      emailConfirmData: null,
      declineModalOpen: false,
      declineBooking: null,

      assignRWModalOpen: false,
      selectedBooking: null,
      historyModalOpen: false,
      historyBooking: null,
      showLearnerForm: false,
      editingLearner: null,
      showTeacherForm: false,
      editingTeacher: null,
      showRWForm: false,
      editingRW: null,
      showVenueForm: false,
      editingVenue: null,
      showSubjectForm: false,
      editingSubject: null
    }),

  // Search actions
  setSearch: (searchType, value) =>
    set((state) => ({
      searches: {
        ...state.searches,
        [searchType]: value
      }
    })),

  clearSearch: (searchType) =>
    set((state) => ({
      searches: {
        ...state.searches,
        [searchType]: ''
      }
    })),

  clearAllSearches: () =>
    set({
      searches: {
        learner: '',
        teacher: '',
        readerWriter: '',
        subject: '',
        venue: '',
        declined: ''
      }
    }),

  // Loading overlay
  setLoading: (show, message = 'Loading...') =>
    set({ showLoading: show, loadingMessage: message }),

  // Notification toast
  showNotification: (message, type = 'info') => {
    set({
      notification: {
        show: true,
        message,
        type
      }
    })

    setTimeout(() => {
      set((state) => ({
        notification: {
          ...state.notification,
          show: false
        }
      }))
    }, 5000)
  },

  hideNotification: () =>
    set((state) => ({
      notification: {
        ...state.notification,
        show: false
      }
    }))
}))
